@model Portfolio.Models.Skill

@{
    ViewData["Title"] = "Delete Skill";
}

<div class="admin-page-header">
    <h1 class="admin-page-title text-danger">
        <span class="prompt-symbol">&gt;</span> skills_matrix --delete --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-red">
    <h3 class="text-danger mb-3" style="font-family: 'JetBrains Mono', monospace;">WARNING: DELETE RECORD</h3>
    <p class="text-light">Are you sure you want to permanently delete this skill?</p>

    <div class="my-4 p-3" style="background: rgba(13, 21, 21, 0.6); border: 1px solid rgba(255, 0, 60, 0.3);">
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Skill Name</div>
            <div class="cyber-details-value text-danger"><strong>@Model.Name</strong></div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Category</div>
            <div class="cyber-details-value">@Model.Category</div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Proficiency</div>
            <div class="cyber-details-value">@Model.ProficiencyLevel%</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-danger">
                <span class="material-symbols-outlined">delete_forever</span> Delete Skill
            </button>
            <a asp-action="Index" class="btn-cyber">Cancel</a>
        </div>
    </form>
</div>
