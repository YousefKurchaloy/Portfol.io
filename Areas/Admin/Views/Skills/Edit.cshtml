@model Portfolio.Models.Skill
@using Portfolio.Models

@{
    ViewData["Title"] = "Edit Skill";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> skills_matrix --update --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-green">
    <form asp-action="Edit" class="cyber-form">
        <div asp-validation-summary="ModelOnly" class="auth-errors mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Name" class="form-label">Skill Name</label>
                    <input asp-for="Name" class="form-control" placeholder="E.g., C#, React, Docker" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Category" class="form-label">Skill Category</label>
                    <select asp-for="Category" asp-items="Html.GetEnumSelectList<ESkillCategory>()" class="form-select"></select>
                    <span asp-validation-for="Category" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="ProficiencyLevel" class="form-label">Proficiency Level (1 - 100%)</label>
                    <input asp-for="ProficiencyLevel" type="number" class="form-control" min="1" max="100" />
                    <span asp-validation-for="ProficiencyLevel" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="IconClass" class="form-label">Icon CSS Class</label>
                    <input asp-for="IconClass" class="form-control" placeholder="E.g., devicon-csharp-plain, fab fa-js" />
                    <span asp-validation-for="IconClass" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                    <span asp-validation-for="DisplayOrder" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-primary">
                <span class="material-symbols-outlined">save</span> Save Changes
            </button>
            <a asp-action="Index" class="btn-cyber btn-danger">Cancel</a>
        </div>
    </form>
</div>


