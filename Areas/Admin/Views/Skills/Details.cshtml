@model Portfolio.Models.Skill

@{
    ViewData["Title"] = "Skill Details";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> skills_matrix --inspect --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Skill Name</div>
        <div class="cyber-details-value">@Model.Name</div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Category</div>
        <div class="cyber-details-value"><span class="badge-cyber">@Model.Category</span></div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Proficiency Level</div>
        <div class="cyber-details-value">
            <div class="d-flex align-items-center gap-2 w-max-250">
                <div class="progress progress-cyber flex-grow-1">
                    <div class="progress-bar progress-bar-cyber" role="progressbar" style="width: @(Model.ProficiencyLevel)%" aria-valuenow="@Model.ProficiencyLevel" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <span>@Model.ProficiencyLevel%</span>
            </div>
        </div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Icon CSS Class</div>
        <div class="cyber-details-value">
            @if (!string.IsNullOrEmpty(Model.IconClass))
            {
                <code>@Model.IconClass</code>
            }
            else
            {
                <span class="text-muted">None Specified</span>
            }
        </div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Display Order</div>
        <div class="cyber-details-value">@Model.DisplayOrder</div>
    </div>

    <div class="mt-4 d-flex gap-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-cyber btn-primary">
            <span class="material-symbols-outlined">edit</span> Edit Skill
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-cyber btn-danger">
            <span class="material-symbols-outlined">delete</span> Delete
        </a>
    </div>
</div>
