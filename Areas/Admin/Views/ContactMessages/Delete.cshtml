@model Portfolio.Models.ContactMessage

@{
    ViewData["Title"] = "Delete Message";
}

<div class="admin-page-header">
    <h1 class="admin-page-title text-danger">
        <span class="prompt-symbol">&gt;</span> contact_inbox --delete --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to Inbox
    </a>
</div>

<div class="admin-card accent-red">
    <h3 class="text-danger mb-3">WARNING: DELETE MESSAGE</h3>
    <p class="text-light">Are you sure you want to permanently delete this message record?</p>

    <div class="my-4 p-3 cyber-warning-box">
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Sender</div>
            <div class="cyber-details-value">@Model.SenderName &lt;@Model.SenderEmail&gt;</div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Subject</div>
            <div class="cyber-details-value">@Model.Subject</div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Date Received</div>
            <div class="cyber-details-value">@Model.SentDate.ToLocalTime().ToString("g")</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-danger">
                <span class="material-symbols-outlined">delete_forever</span> Confirm Purge
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cyber">Cancel</a>
        </div>
    </form>
</div>
