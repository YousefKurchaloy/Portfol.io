@model IEnumerable<Portfolio.Models.PlatformProfile>

@{
    ViewData["Title"] = "Platform Profiles";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> platform_profiles --list
    </h1>
    <a asp-action="Create" class="btn-cyber btn-primary">
        <span class="material-symbols-outlined">add</span> Add Platform Profile
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-table-container">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Platform</th>
                    <th>User Handle</th>
                    <th>Rank</th>
                    <th>Profile URL</th>
                    <th>Order</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No records found. Run platform_profiles --seed.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.PlatformName</strong>
                            </td>
                            <td>
                                <code>@item.UserHandle</code>
                            </td>
                            <td>
                                @(item.Rank ?? "N/A")
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ProfileUrl))
                                {
                                    <a href="@item.ProfileUrl" target="_blank" class="badge-cyber primary" style="text-decoration: none;">Link to Profile</a>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td>
                                @item.DisplayOrder
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-cyber btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-cyber btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-cyber btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
