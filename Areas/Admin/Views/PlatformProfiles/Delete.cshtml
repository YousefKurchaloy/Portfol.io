@model Portfolio.Models.PlatformProfile

@{
    ViewData["Title"] = "Delete Profile";
}

<div class="admin-page-header">
    <h1 class="admin-page-title text-danger">
        <span class="prompt-symbol">&gt;</span> platform_profiles --delete --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-red">
    <h3 class="text-danger mb-3">WARNING: PURGE RECORD</h3>
    <p class="text-light">Are you sure you want to permanently delete this platform profile?</p>

    <div class="my-4 p-3 cyber-warning-box">
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Platform Name</div>
            <div class="cyber-details-value text-danger"><strong>@Model.PlatformName</strong></div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">User Handle</div>
            <div class="cyber-details-value"><code>@Model.UserHandle</code></div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-danger">
                <span class="material-symbols-outlined">delete_forever</span> Confirm Purge
            </button>
            <a asp-action="Index" class="btn-cyber">Cancel</a>
        </div>
    </form>
</div>
