<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Portfol.io Admin</title>

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;600&family=JetBrains+Mono:wght@400;600;700&display=swap"
          rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet" />

    <!-- Icon Fonts -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body>
    <div class="bg-grid-pattern"></div>

    <div class="admin-shell">
        <!-- Sidebar Navigation -->
        <aside class="admin-sidebar" id="sidebar">
            <a href="/" class="sidebar-brand">
                <span class="material-symbols-outlined text-primary">terminal</span>
                <span>Portfol.io</span>
            </a>

            <div class="sidebar-user">
                <div class="user-role">System Administrator</div>
                <div class="user-name" title="@User.Identity?.Name">@User.Identity?.Name</div>
            </div>

            <ul class="sidebar-menu">
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <span class="material-symbols-outlined">dashboard</span>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Profile" asp-action="Index">
                        <span class="material-symbols-outlined">person</span>
                        <span>Edit Profile</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Projects" asp-action="Index">
                        <span class="material-symbols-outlined">terminal</span>
                        <span>Projects</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Skills" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Skills" asp-action="Index">
                        <span class="material-symbols-outlined">construction</span>
                        <span>Skills</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Credentials" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Credentials" asp-action="Index">
                        <span class="material-symbols-outlined">workspace_premium</span>
                        <span>Credentials</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "TimelineEvents" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="TimelineEvents" asp-action="Index">
                        <span class="material-symbols-outlined">timeline</span>
                        <span>Timeline</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "PlatformProfiles" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="PlatformProfiles" asp-action="Index">
                        <span class="material-symbols-outlined">account_circle</span>
                        <span>Profiles</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "ContactMessages" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index">
                        <span class="material-symbols-outlined">mail</span>
                        <span>Messages</span>
                    </a>
                </li>
            </ul>

            <div class="menu-footer">
                <form asp-area="Admin" asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm">
                    <button type="submit" class="btn-logout">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Shutdown Session</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="admin-main">
            <!-- Sidebar toggle button for smaller viewports -->
            <button class="btn-cyber d-lg-none mb-3" onclick="toggleSidebar()" aria-label="Toggle Navigation">
                <span class="material-symbols-outlined">menu</span> Menu
            </button>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
