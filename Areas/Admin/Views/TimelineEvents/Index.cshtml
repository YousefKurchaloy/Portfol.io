@model IEnumerable<Portfolio.Models.TimelineEvent>

@{
    ViewData["Title"] = "Timeline Events";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> timeline_log --list
    </h1>
    <a asp-action="Create" class="btn-cyber btn-primary">
        <span class="material-symbols-outlined">add</span> Add Timeline Event
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-table-container">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Organization</th>
                    <th>Type</th>
                    <th>Dates</th>
                    <th>Order</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No records found. Run timeline_log --seed.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Title</strong>
                            </td>
                            <td>
                                @item.Organization
                                @if (!string.IsNullOrEmpty(item.Location))
                                {
                                    <span class="text-muted">(@item.Location)</span>
                                }
                            </td>
                            <td>
                                <span class="badge-cyber primary">@item.EventType</span>
                            </td>
                            <td>
                                @item.StartDate.ToString("yyyy-MM") to @(item.EndDate?.ToString("yyyy-MM") ?? "Present")
                            </td>
                            <td>
                                @item.DisplayOrder
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-cyber btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-cyber btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-cyber btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
