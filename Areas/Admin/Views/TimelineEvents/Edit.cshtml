@model Portfolio.Models.TimelineEvent
@using Portfolio.Models

@{
    ViewData["Title"] = "Edit Timeline Event";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> timeline_log --update --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-green">
    <form asp-action="Edit" class="cyber-form">
        <div asp-validation-summary="ModelOnly" class="auth-errors mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Title" class="form-label">Event Title / Role</label>
                    <input asp-for="Title" class="form-control" placeholder="E.g., Senior Systems Architect, B.Sc. Computer Science" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Organization" class="form-label">Organization / Institution</label>
                    <input asp-for="Organization" class="form-control" placeholder="E.g., Google, MIT" />
                    <span asp-validation-for="Organization" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Location" class="form-label">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="E.g., London, UK (Remote)" />
                    <span asp-validation-for="Location" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="EventType" class="form-label">Event Type</label>
                    <select asp-for="EventType" asp-items="Html.GetEnumSelectList<ETimelineEventType>()" class="form-select"></select>
                    <span asp-validation-for="EventType" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="EndDate" class="form-label">End Date (Leave empty if current/ongoing)</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="form-label">Detailed Description</label>
            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Highlight key achievements, projects completed, or courses taken..."></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-primary">
                <span class="material-symbols-outlined">save</span> Save Changes
            </button>
            <a asp-action="Index" class="btn-cyber btn-danger">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
