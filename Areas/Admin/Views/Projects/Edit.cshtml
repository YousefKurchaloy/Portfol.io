@model Portfolio.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> project_db --update --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-green">
    <form asp-action="Edit" class="cyber-form">
        <div asp-validation-summary="ModelOnly" class="auth-errors mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Title" class="form-label">Project Title</label>
                    <input asp-for="Title" class="form-control" placeholder="E.g., Quantum Portfolio" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="CompletionDate" class="form-label">Completion Date (Leave empty if in-progress)</label>
                    <input asp-for="CompletionDate" type="date" class="form-control" />
                    <span asp-validation-for="CompletionDate" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="RepositoryUrl" class="form-label">Repository URL</label>
                    <input asp-for="RepositoryUrl" type="url" class="form-control" placeholder="https://github.com/..." />
                    <span asp-validation-for="RepositoryUrl" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="LiveDemoUrl" class="form-label">Live Demo URL</label>
                    <input asp-for="LiveDemoUrl" type="url" class="form-control" placeholder="https://demo.portfol.io" />
                    <span asp-validation-for="LiveDemoUrl" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="ImageUrl" class="form-label">Cover Image URL</label>
                    <input asp-for="ImageUrl" type="url" class="form-control" placeholder="https://images.portfol.io/..." />
                    <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                    <input asp-for="DisplayOrder" class="form-control" type="number" />
                    <span asp-validation-for="DisplayOrder" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group pt-4">
                    <div class="form-check auth-checkbox">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="IsFeatured" />
                        <label asp-for="IsFeatured" class="form-check-label" for="IsFeatured">Pin to Featured Projects</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="form-label">Project Description</label>
            <textarea asp-for="Description" class="form-control" rows="6" placeholder="Provide details, technology stack used, architecture constraints..."></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-primary">
                <span class="material-symbols-outlined">save</span> Save Changes
            </button>
            <a asp-action="Index" class="btn-cyber btn-danger">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}