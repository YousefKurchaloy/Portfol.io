@model IEnumerable<Portfolio.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> projects_db --list
    </h1>
    <a asp-action="Create" class="btn-cyber btn-primary">
        <span class="material-symbols-outlined">add</span> Create New Project
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-table-container">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Completion Date</th>
                    <th>Order</th>
                    <th>Featured</th>
                    <th>Links</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No records found. Run project_db --seed.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <partial name="_ProjectRowPartial" model="item" />
                    }
                }
            </tbody>
        </table>
    </div>
</div>