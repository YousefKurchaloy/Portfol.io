@model IEnumerable<Portfolio.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> projects_db --list
    </h1>
    <a asp-action="Create" class="btn-cyber btn-primary">
        <span class="material-symbols-outlined">add</span> Create New Project
    </a>
</div>

<div class="mt-4 mb-5 p-3 rounded" style="background: rgba(0, 243, 255, 0.03); border: 1px dashed rgba(0, 243, 255, 0.2);">
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-3" style="max-width: 700px;">
        
        <div class="flex-grow-1" style="margin: 0;">
            <input type="text" 
                   name="SearchString" 
                   value="@ViewData["CurrentFilter"]" 
                   class="form-control" 
                   placeholder="> search_projects --title..." 
                   style="font-family: 'JetBrains Mono', monospace; 
                          border: 1px solid var(--secondary-accent); 
                          padding: 0.75rem 1.25rem; 
                          background-color: rgba(0, 0, 0, 0.5); 
                          color: #fff;" />
        </div>
        
        <button type="submit" class="btn-cyber btn-primary" style="margin: 0; padding: 0.75rem 1.5rem;">
            <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem; margin-right: 6px;">search</span> 
            Execute
        </button>
        
        <a asp-action="Index" class="btn-cyber" style="margin: 0; padding: 0.75rem 1.5rem;">
            <span class="material-symbols-outlined align-middle" style="font-size: 1.2rem; margin-right: 6px;">backspace</span> 
            Clear
        </a>
    </form>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-table-container">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Completion Date</th>
                    <th>Order</th>
                    <th>Featured</th>
                    <th>Links</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No records found. Run project_db --seed.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <partial name="_ProjectRowPartial" model="item" />
                    }
                }
            </tbody>
        </table>
    </div>
</div>