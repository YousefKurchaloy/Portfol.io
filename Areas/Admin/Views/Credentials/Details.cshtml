@model Portfolio.Models.Credential

@{
    ViewData["Title"] = "Credential Details";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> credentials_vault --inspect --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Credential Name</div>
        <div class="cyber-details-value">@Model.Name</div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Issuing Authority</div>
        <div class="cyber-details-value">@Model.IssuingAuthority</div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Issue Date</div>
        <div class="cyber-details-value">@Model.IssueDate.ToString("yyyy-MM-dd")</div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Expiry Date</div>
        <div class="cyber-details-value">@(Model.ExpiryDate?.ToString("yyyy-MM-dd") ?? "Never Expires")</div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Verification URL</div>
        <div class="cyber-details-value">
            @if (!string.IsNullOrEmpty(Model.VerificationUrl))
            {
                <a href="@Model.VerificationUrl" target="_blank" style="color: var(--primary-accent);">@Model.VerificationUrl</a>
            }
            else
            {
                <span class="text-muted">None</span>
            }
        </div>
    </div>
    <div class="cyber-details-grid">
        <div class="cyber-details-label">Badge Image URL</div>
        <div class="cyber-details-value">
            @if (!string.IsNullOrEmpty(Model.BadgeUrl))
            {
                <a href="@Model.BadgeUrl" target="_blank" style="color: var(--secondary-accent);">@Model.BadgeUrl</a>
            }
            else
            {
                <span class="text-muted">None</span>
            }
        </div>
    </div>

    <div class="mt-4 d-flex gap-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-cyber btn-primary">
            <span class="material-symbols-outlined">edit</span> Edit Credential
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-cyber btn-danger">
            <span class="material-symbols-outlined">delete</span> Delete
        </a>
    </div>
</div>
