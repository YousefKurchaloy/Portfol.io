@model Portfolio.Models.Credential

@{
    ViewData["Title"] = "Add Credential";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> credentials_vault --insert
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-blue">
    <form asp-action="Create" class="cyber-form">
        <div asp-validation-summary="ModelOnly" class="auth-errors mb-3"></div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Name" class="form-label">Credential Name</label>
                    <input asp-for="Name" class="form-control" placeholder="E.g., AWS Certified Solutions Architect" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="IssuingAuthority" class="form-label">Issuing Authority</label>
                    <input asp-for="IssuingAuthority" class="form-control" placeholder="E.g., Amazon Web Services" />
                    <span asp-validation-for="IssuingAuthority" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="IssueDate" class="form-label">Issue Date</label>
                    <input asp-for="IssueDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="IssueDate" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ExpiryDate" class="form-label">Expiry Date (Leave empty if none)</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" />
                    <span asp-validation-for="ExpiryDate" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="VerificationUrl" class="form-label">Verification URL</label>
                    <input asp-for="VerificationUrl" type="url" class="form-control" placeholder="https://www.credly.com/..." />
                    <span asp-validation-for="VerificationUrl" class="field-validation-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="BadgeUrl" class="form-label">Badge Image URL</label>
                    <input asp-for="BadgeUrl" type="url" class="form-control" placeholder="https://images.credly.com/..." />
                    <span asp-validation-for="BadgeUrl" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-group mb-5">
            <label class="form-label mb-3">Associated Skills / Proficiencies</label>
            <div class="row">
                @if (ViewBag.Skills != null)
                {
                    var skillsList = (List<Portfolio.Models.Skill>)ViewBag.Skills;
                    var selectedSkillIds = (List<int>)(ViewBag.SelectedSkillIds ?? new List<int>());
                    var groupedSkills = skillsList.GroupBy(s => s.Category);

                    if (skillsList.Any())
                    {
                        foreach (var group in groupedSkills)
                        {
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="text-accent font-mono small border-bottom border-secondary-subtle pb-1 mb-2">
                                    &gt; @group.Key.ToString()
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var skill in group)
                                    {
                                        var isChecked = selectedSkillIds.Contains(skill.Id);
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="selectedSkillIds" value="@skill.Id" id="skill_@skill.Id" @(isChecked ? "checked" : "") />
                                            <label class="form-check-label" for="skill_@skill.Id">
                                                @skill.Name
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-muted font-mono small ps-3">
                            No skills registered. Please add skills first under the Skills section.
                        </div>
                    }
                }
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-primary">
                <span class="material-symbols-outlined">save</span> Save Credential
            </button>
            <a asp-action="Index" class="btn-cyber btn-danger">Cancel</a>
        </div>
    </form>
</div>


