@model Portfolio.Models.Credential

@{
    ViewData["Title"] = "Delete Credential";
}

<div class="admin-page-header">
    <h1 class="admin-page-title text-danger">
        <span class="prompt-symbol">&gt;</span> credentials_vault --delete --id=@Model.Id
    </h1>
    <a asp-action="Index" class="btn-cyber">
        <span class="material-symbols-outlined">arrow_back</span> Back to List
    </a>
</div>

<div class="admin-card accent-red">
    <h3 class="text-danger mb-3">WARNING: IRREVERSIBLE DELETE</h3>
    <p class="text-light">Are you sure you want to permanently purge this credential from the system?</p>

    <div class="my-4 p-3 cyber-warning-box">
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Credential Name</div>
            <div class="cyber-details-value text-danger"><strong>@Model.Name</strong></div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Issuing Authority</div>
            <div class="cyber-details-value">@Model.IssuingAuthority</div>
        </div>
        <div class="cyber-details-grid">
            <div class="cyber-details-label">Issue Date</div>
            <div class="cyber-details-value">@Model.IssueDate.ToString("yyyy-MM-dd")</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn-cyber btn-danger">
                <span class="material-symbols-outlined">delete_forever</span> Confirm Purge
            </button>
            <a asp-action="Index" class="btn-cyber">Cancel</a>
        </div>
    </form>
</div>
