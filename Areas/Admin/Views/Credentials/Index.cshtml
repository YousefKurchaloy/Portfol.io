@model IEnumerable<Portfolio.Models.Credential>

@{
    ViewData["Title"] = "Credentials";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">
        <span class="prompt-symbol">&gt;</span> credentials_vault --list
    </h1>
    <a asp-action="Create" class="btn-cyber btn-primary">
        <span class="material-symbols-outlined">add</span> Add Credential
    </a>
</div>

<div class="admin-card accent-blue">
    <div class="cyber-table-container">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Authority</th>
                    <th>Issue Date</th>
                    <th>Expiry Date</th>
                    <th>Links</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No records found. Run credentials_vault --seed.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>
                            <td>
                                @item.IssuingAuthority
                            </td>
                            <td>
                                @item.IssueDate.ToString("yyyy-MM-dd")
                            </td>
                            <td>
                                @(item.ExpiryDate?.ToString("yyyy-MM-dd") ?? "Never Expires")
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.VerificationUrl))
                                {
                                    <a href="@item.VerificationUrl" target="_blank" class="badge-cyber primary" style="text-decoration: none;">Verify</a>
                                }
                                @if (!string.IsNullOrEmpty(item.BadgeUrl))
                                {
                                    <a href="@item.BadgeUrl" target="_blank" class="badge-cyber active" style="text-decoration: none;">Badge</a>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-cyber btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-cyber btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-cyber btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
